# ---------------------------------------------------------------------------
# Qdrant storage mode — pick ONE:
#
#   A) Embedded on-disk (default, like ChromaDB — no Docker, no cloud):
#        leave QDRANT_URL unset; vectors are written to QDRANT_PATH.
#   B) Local Docker server:   QDRANT_URL=http://localhost:6333
#   C) Qdrant Cloud:          QDRANT_URL=https://xxxx.cloud.qdrant.io:6333
#                             QDRANT_API_KEY=your-key
# ---------------------------------------------------------------------------
QDRANT_PATH=./qdrant_storage
# QDRANT_URL=
# QDRANT_API_KEY=

# Collection + chunking
COLLECTION_NAME=rag_docs
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Models (retrieval)
DENSE_MODEL=BAAI/bge-m3
SPARSE_MODEL=Qdrant/bm25
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# LLM — generator (agent answers + routing). Providers: openai | groq | gemini.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# GROQ_API_KEY=          # if LLM_PROVIDER=groq
# GOOGLE_API_KEY=        # if LLM_PROVIDER=gemini

# RAGAS judge — use a DIFFERENT model than the generator (avoids self-eval bias).
JUDGE_PROVIDER=groq
JUDGE_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# Agent behavior
GROUNDING_THRESHOLD=0.05
TOP_K=5
